{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "iTools 主窗口所需的核心权限",
  "windows": ["main", "admin"],
  "permissions": [
    "core:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:window:allow-center",
    "core:window:allow-set-size",
    "core:window:allow-start-dragging",
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "core:window:allow-unmaximize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-is-maximized",
    "core:window:allow-close",
    "core:event:default",
    "allow-search",
    "allow-execute",
    "allow-load-icons",
    "allow-home-data",
    "allow-toggle-pin",
    "allow-get-settings",
    "allow-save-settings",
    "allow-pick-image",
    "allow-pick-app",
    "allow-read-image",
    "allow-read-avatar",
    "allow-get-profile",
    "allow-set-nickname",
    "allow-set-avatar",
    "allow-account-state",
    "allow-account-login",
    "allow-set-data-sync",
    "allow-sync-now",
    "allow-logout-account",
    "allow-delete-account",
    "allow-pick-launch-files",
    "allow-pick-launch-folder",
    "allow-add-launch-items",
    "allow-remove-launch-items",
    "allow-run-launch-item",
    "allow-build-launch-item",
    "allow-open-admin-window",
    "allow-close-admin-window",
    "allow-set-settings-persist",
    "allow-check-update",
    "allow-get-app-version",
    "allow-open-release-page",
    "allow-download-update",
    "allow-launch-installer-and-quit",
    "allow-open-plugin-window",
    "allow-rescan-plugins",
    "allow-list-plugins",
    "allow-set-plugin-enabled",
    "allow-set-plugin-permission",
    "allow-delete-plugin",
    "allow-plugin-readme",
    "allow-plugin-settings-schema",
    "allow-plugin-settings-values",
    "allow-plugin-settings-set",
    "allow-plugin-settings-reset"
  ]
}
