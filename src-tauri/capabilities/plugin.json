{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "plugin",
  "description": "插件页面窗口（label=plugin，itplugin 自定义协议远程源）的受控 IPC。Tauri v2 中 App 自有命令经 build.rs 的 AppManifest 纳入 ACL 后，本 capability 只授予下列 plugin_* 白名单命令——插件页无法调用 execute / save_settings 等主程序命令。",
  "windows": ["plugin"],
  "remote": {
    "urls": ["http://itplugin.localhost", "http://itplugin.localhost/*"]
  },
  "permissions": [
    "core:event:default",
    "allow-plugin-take-enter",
    "allow-plugin-hide",
    "allow-plugin-exit",
    "allow-plugin-set-height",
    "allow-plugin-copy-text",
    "allow-plugin-read-text",
    "allow-plugin-read-image",
    "allow-plugin-write-image",
    "allow-plugin-save-image",
    "allow-plugin-read-file",
    "allow-plugin-write-file",
    "allow-plugin-remove-file",
    "allow-plugin-open-external",
    "allow-plugin-open-path",
    "allow-plugin-notify",
    "allow-plugin-run-command",
    "allow-plugin-fetch",
    "allow-plugin-db-get",
    "allow-plugin-db-set",
    "allow-plugin-db-remove",
    "allow-plugin-db-keys",
    "allow-plugin-list-displays",
    "allow-plugin-capture-full",
    "allow-plugin-capture-region",
    "allow-plugin-register-hotkey",
    "allow-plugin-unregister-hotkey",
    "allow-plugin-create-pin",
    "allow-plugin-ocr",
    "allow-plugin-start-audio-record",
    "allow-plugin-stop-audio-record",
    "allow-plugin-start-gif-record",
    "allow-plugin-stop-gif-record",
    "allow-plugin-account-state",
    "allow-plugin-data-get",
    "allow-plugin-data-set",
    "allow-plugin-data-remove",
    "allow-plugin-data-keys",
    "allow-plugin-data-sync",
    "allow-plugin-get-settings",
    "allow-plugin-get-setting"
  ]
}
