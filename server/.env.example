# iTools 云同步服务端配置（复制为 .env 或直接在环境里 export）
# 监听地址与端口
SYNC_HOST=127.0.0.1
SYNC_PORT=8787
# 数据持久化文件（JSON，原子写）
SYNC_DATA_FILE=./data/db.json
# 是否允许「首次登录即自动注册」（自托管场景默认开启，方便直接用）
SYNC_ALLOW_REGISTER=true
# 会话令牌随机字节数
SYNC_TOKEN_BYTES=32
# 是否打印访问日志
SYNC_LOG=true

# 客户端侧：让 iTools 指向本服务端后，登录/云同步即真实生效
#   ITOOLS_SYNC_ENDPOINT=http://127.0.0.1:8787
